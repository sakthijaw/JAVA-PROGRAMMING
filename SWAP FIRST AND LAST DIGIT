import java.util.*;
public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
	    int n=sc.nextInt();
	    int count=0;
	    int temp=n;
	    while(temp!=0){
	        temp=temp/10;
	        count++;
	    }
	    int last=n%10;
	    int first=n/(int)Math.pow(10,count-1);
	    int mid=n%(int)Math.pow(10,count-1)/10;
	    int con=(last*(int)Math.pow(10,count-2)+mid)*10+first;
	    
		System.out.println(con);
	}
}
